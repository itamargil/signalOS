# ─── Supabase ───────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server only, NEVER exposed to the browser
SUPABASE_SERVICE_ROLE_KEY=

# ─── Anthropic (the agent) ──────────────────────────────────
ANTHROPIC_API_KEY=
# Default model for agent reasoning/analysis
ANTHROPIC_MODEL=claude-opus-4-8

# ─── Reddit (read-only) ─────────────────────────────────────
# Three modes, auto-selected by what's set (see src/lib/sources/reddit.ts):
#   1. Leave ALL blank → uses public reddit.com/*.json endpoints (no key,
#      fine for low-volume research). This is the zero-setup default.
#   2. REDDIT_API_KEY → used as a bearer token (falls back to public if rejected).
#   3. REDDIT_CLIENT_ID + REDDIT_CLIENT_SECRET → full OAuth, best rate limits.
#      Create a "script" app at https://www.reddit.com/prefs/apps
#      (NOTE: developers.reddit.com / Devvit is a different product, not this.)
REDDIT_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=signalos/0.1 by yourusername
# Reddit closed self-service API access (Nov 2025) and 403s public .json
# (May 2026), so with no OAuth creds we read Reddit via Apify. Override the
# actor if you like; default returns upvotes/comments + engagement velocity.
REDDIT_APIFY_ACTOR=harshmaur/reddit-scraper

# ─── Apify (X + Instagram scraping) ─────────────────────────
# https://console.apify.com/account/integrations
APIFY_TOKEN=
# Actor IDs (defaults are common community actors; override if you prefer others)
APIFY_INSTAGRAM_ACTOR=apify/instagram-scraper
# Default X actor runs on the Apify free tier. apidojo/tweet-scraper requires a
# PAID Apify plan, so it's avoided.
APIFY_X_ACTOR=xquik/x-tweet-scraper

# ─── Email notifications (Resend) ───────────────────────────
RESEND_API_KEY=
NOTIFY_EMAIL_TO=itamargil8@gmail.com
NOTIFY_EMAIL_FROM=SignalOS <onboarding@resend.dev>

# ─── Inngest (durable multi-day workflow) ───────────────────
# Local dev works with NO keys via `npm run inngest`.
# For production set the event + signing keys (https://app.inngest.com → Keys),
# OR set a single INNGEST_API_KEY which is used as a fallback for both.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_API_KEY=

# ─── App ────────────────────────────────────────────────────
# Public base URL (used in approval email links)
APP_URL=http://localhost:3000
